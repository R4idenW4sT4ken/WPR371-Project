<%- include('../Partials/header') %>

<h2 class="mb-4">Edit Event</h2>

<% if (errors && errors.length) { %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% errors.forEach(error => { %>
        <li><%= error %></li>
      <% }); %>
    </ul>
  </div>
<% } %>

<form method="POST" action="/admin/events/<%= event._id %>?_method=PUT" class="mx-auto" style="max-width: 700px;">
  <div class="mb-3">
    <label class="form-label">Title</label>
    <input type="text" name="title" class="form-control" value="<%= event.title %>" required>
  </div>
  <div class="mb-3">
    <label class="form-label">Category</label>
    <input type="text" name="category" class="form-control" value="<%= event.category || '' %>">
  </div>
  <div class="row">
    <div class="col-md-6 mb-3">
      <label class="form-label">Date</label>
      <input type="date" name="date" class="form-control" value="<%= event.date ? new Date(event.date).toISOString().slice(0, 10) : '' %>" required>
    </div>
    <div class="col-md-6 mb-3">
      <label class="form-label">Location</label>
      <input type="text" name="location" class="form-control" value="<%= event.location %>" required>
    </div>
  </div>
  <div class="mb-3">
    <label class="form-label">Capacity</label>
    <input type="number" name="capacity" min="0" class="form-control" value="<%= event.capacity || 0 %>">
  </div>
  <div class="mb-3">
    <label class="form-label">Image URL</label>
    <input type="text" name="image" class="form-control" value="<%= event.image %>" required>
  </div>
  <div class="mb-3">
    <label class="form-label">Description</label>
    <textarea name="description" class="form-control" rows="3"><%= event.description || '' %></textarea>
  </div>
  <div class="mb-3">
    <label class="form-label">Details</label>
    <textarea name="details" class="form-control" rows="3"><%= event.details || '' %></textarea>
  </div>
  <div class="row">
    <div class="col-md-6 mb-3">
      <label class="form-label">Rules</label>
      <textarea name="rules" class="form-control" rows="2"><%= event.rules || '' %></textarea>
    </div>
    <div class="col-md-6 mb-3">
      <label class="form-label">Bring</label>
      <textarea name="bring" class="form-control" rows="2"><%= event.bring || '' %></textarea>
    </div>
  </div>
  <div class="row">
    <div class="col-md-6 mb-3">
      <label class="form-label">Weather</label>
      <textarea name="weather" class="form-control" rows="2"><%= event.weather || '' %></textarea>
    </div>
    <div class="col-md-6 mb-3">
      <label class="form-label">Dress</label>
      <textarea name="dress" class="form-control" rows="2"><%= event.dress || '' %></textarea>
    </div>
  </div>
  <div class="row">
    <div class="col-md-6 mb-3">
      <label class="form-label">Parking</label>
      <textarea name="parking" class="form-control" rows="2"><%= event.parking || '' %></textarea>
    </div>
    <div class="col-md-6 mb-3">
      <label class="form-label">Accessibility</label>
      <textarea name="accessibility" class="form-control" rows="2"><%= event.accessibility || '' %></textarea>
    </div>
  </div>
  <div class="mb-3">
    <label class="form-label">Food</label>
    <textarea name="food" class="form-control" rows="2"><%= event.food || '' %></textarea>
  </div>
  <div class="text-end">
    <button type="submit" class="btn btn-primary">Save Changes</button>
  </div>
</form>

<%- include('../Partials/footer') %>
