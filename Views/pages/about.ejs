<%- include('../Partials/header') %>

<h1>About Us</h1>

<section class="text-center mb-5">
  <h2 class="display-5">Meet the Team</h2>
  <p class="lead text-muted">Dedicated to building a stronger community through innovation.</p>
</section>

<div class="row justify-content-center">
  <% teamMembers.forEach(function(member) { %>
    <div class="col-md-3 col-sm-6 mb-4">
      <div class="card shadow-sm border-0 h-100 text-center">
        <div class="card-body">
          <img src="/images/team/<%= member.image %>" class="card-img-top rounded-circle mx-auto" alt="<%= member.name %>" style="width: 120px; height: 120px; object-fit: cover;">
          <h5 class="card-title mb-1"><%= member.name %></h5>
          <p class="text-muted small"><%= member.role %></p>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<%- include('../Partials/footer') %>