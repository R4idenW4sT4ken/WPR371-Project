<%- include('../Partials/header') %>

<section class="mb-4">
  <h2 class="mb-3"><%= event.title %></h2>
  <img src="<%= event.image %>" alt="<%= event.title %>" class="img-fluid mb-3">
  <p><strong>Date:</strong> <%= event.date ? new Date(event.date).toISOString().slice(0, 10) : 'TBD' %></p>
  <p><strong>Location:</strong> <%= event.location %></p>
  <p><strong>Category:</strong> <%= event.category || 'General' %></p>
  <p><strong>Capacity:</strong> <%= event.capacity || 'Unlimited' %></p>
  <p><strong>Tickets Booked:</strong> <%= event.ticketsBooked %></p>
  <p><strong>Available:</strong> <%= availableTickets === null ? 'Unlimited' : availableTickets %></p>

  <% if (event.description) { %>
    <h4>Description</h4>
    <p><%= event.description %></p>
  <% } %>

  <% if (event.details) { %>
    <h4>Details</h4>
    <p><%= event.details %></p>
  <% } %>

  <% if (event.rules) { %>
    <h4>Rules</h4>
    <p><%= event.rules %></p>
  <% } %>

  <div class="row">
    <div class="col-md-6">
      <% if (event.bring) { %>
        <h5>What to Bring</h5>
        <p><%= event.bring %></p>
      <% } %>
      <% if (event.weather) { %>
        <h5>Weather</h5>
        <p><%= event.weather %></p>
      <% } %>
    </div>
    <div class="col-md-6">
      <% if (event.dress) { %>
        <h5>Dress Code</h5>
        <p><%= event.dress %></p>
      <% } %>
      <% if (event.parking) { %>
        <h5>Parking</h5>
        <p><%= event.parking %></p>
      <% } %>
      <% if (event.accessibility) { %>
        <h5>Accessibility</h5>
        <p><%= event.accessibility %></p>
      <% } %>
      <% if (event.food) { %>
        <h5>Food</h5>
        <p><%= event.food %></p>
      <% } %>
    </div>
  </div>

  <% if (user) { %>
    <form action="/events/<%= event._id %>/book" method="POST" class="mt-4">
      <div class="row align-items-center">
        <div class="col-md-3 mb-3">
          <label class="form-label">Tickets</label>
          <input type="number" name="tickets" min="1" value="1" class="form-control" required>
        </div>
        <div class="col-md-9 mb-3">
          <button type="submit" class="btn btn-primary mt-4">Book Tickets</button>
        </div>
      </div>
    </form>
  <% } else { %>
    <div class="alert alert-info mt-4">
      Please <a href="/login">log in</a> to book tickets for this event.
    </div>
  <% } %>

  <div class="d-flex justify-content-between mt-4">
    <% if (prevEvent) { %>
      <a class="btn btn-outline-secondary" href="/events/<%= prevEvent._id %>">← Previous</a>
    <% } else { %>
      <span></span>
    <% } %>

    <% if (nextEvent) { %>
      <a class="btn btn-outline-primary" href="/events/<%= nextEvent._id %>">Next →</a>
    <% } %>
  </div>
</section>

<%- include('../Partials/footer') %>
