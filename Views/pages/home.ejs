<%
  // home.ejs
  // Home/Landing page for the Community Portal.
  // Shows welcome, featured event, team, and navigation to other sections.
%>

<%- include('../Partials/header') %>

<section class="text-center py-5 bg-light">
  <h1 class="display-4 fw-bold">Welcome to the Community Portal</h1>
  <p class="lead text-muted">Connecting people, promoting events, and building a better future together.</p>
  <% if (user && user.role === 'admin') { %>
    <a href="/admin/events/new" class="btn btn-outline-primary mt-3">Post a New Event</a>
  <% } else if (!user) { %>
    <a href="/login" class="btn btn-outline-primary mt-3">Login to Book Events</a>
  <% } %>
</section>

<section class="bg-primary text-white py-5" id="mainevent">
  <div class="container">
    <h2 class="mb-4 text-center">Featured Event</h2>
    <% if (featuredEvent) { %>
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card border-0 shadow-sm bg-light text-dark">
            <img src="<%= featuredEvent.image %>" class="card-img-top" alt="<%= featuredEvent.title %>">
            <div class="card-body">
              <h3 class="card-title"><%= featuredEvent.title %></h3>
              <p class="card-text"><%= featuredEvent.description || 'Learn more about this event and join us.' %></p>
              <p class="mb-1"><strong>Date:</strong> <%= featuredEvent.date ? new Date(featuredEvent.date).toISOString().slice(0, 10) : 'TBD' %></p>
              <p class="mb-0"><strong>Location:</strong> <%= featuredEvent.location %></p>
              <a href="/events/<%= featuredEvent._id %>" class="btn btn-primary mt-3">View Event</a>
            </div>
          </div>
        </div>
      </div>
    <% } else { %>
      <p class="lead">No featured event is available yet. Check back soon.</p>
    <% } %>
  </div>
</section>

<section class="bg-white text-dark py-5 " >
  <div class="container text-center" >
    <h2 class="mb-4">Meet the Team</h2>
    <div class="row justify-content-center">
      <% teamMembers.forEach(function(member){ %>
        <div class="col-md-3 col-sm-6 mb-4">
          <div class="card shadow-sm border-0">
            <% if (member.image) { %>
              <img src="/images/team/<%= member.image %>" class="card-img-top rounded-circle mx-auto" alt="<%= member.name %>" style="width: 120px; height: 120px; object-fit: cover;">
            <% } else { %>
              <i class="bi bi-person-circle display-1 text-primary my-3"></i>
            <% } %>
            <div class="card-body">
              <h5 class="card-title"><%= member.name %></h5>
              <p class="card-text text-muted small"><%= member.role %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="bg-light py-5">
  <div class="container text-center">
    <h2 class="mb-4">Upcoming Events</h2>
    <p class="lead">Stay up to date with local happenings.</p>
    <a href="/events" class="btn btn-primary">View All Events</a>
  </div>
</section>

<section class="bg-dark text-white py-5">
  <div class="container text-center">
    <h2 class="mb-4 text-white">Get In Touch</h2>
    <p class="lead text-white">We'd love to hear from you.</p>
    <a href="/contact" class="btn btn-outline-light">Contact Us</a>
  </div>
</section>


<script src="/js/home.js"></script>

<%- include('../Partials/footer') %>
